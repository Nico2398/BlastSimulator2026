# Copy to .env and fill in your values
# NEVER commit .env to git

# LLM provider — change prefix to switch provider:
#   deepseek:deepseek-v4-flash  → DEEPSEEK_API_KEY
#   openai:gpt-4o               → OPENAI_API_KEY
#   anthropic:claude-3-7-sonnet → ANTHROPIC_API_KEY
LLM_MODEL_ID=deepseek:deepseek-v4-flash

DEEPSEEK_API_KEY=your-deepseek-key-here
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# GitHub
GITHUB_TOKEN=ghp_your_token_here
DEFAULT_REPO_OWNER=Nico2398
DEFAULT_REPO_NAME=BlastSimulator2026

# LangSmith tracing (optional — leave blank to disable)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=BlastSimulator2026-langgraph

# Issue to work on (for local runs)
ISSUE_NUMBER=1
COMMENT_BODY=
