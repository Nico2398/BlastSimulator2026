{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "pipeline",
  "permission": {
    "bash": {
      "*": "allow"
    }
  },
  "agent": {
    "pipeline": {
      "mode": "primary",
      "description": "Orchestrates the TDD development pipeline. Invokes specialist agents in the correct sequence.",
      "permission": {
        "bash": {
          "*": "allow",
          "git *": "allow",
          "gh *": "allow"
        }
      }
    }
  },
  "instructions": ["AGENTS.md"]
}
